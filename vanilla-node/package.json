    "cors": "^2.8.6",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.64.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/cors": "^2.8.19",
    "@types/node": "^25.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
