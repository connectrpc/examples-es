{
  "name": "buf-vue",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview --port 4173",
    "test": "vitest run --environment jsdom",
    "generate": "buf generate",
    "test:e2e": "npm run build && start-server-and-test preview http://localhost:4173/ 'cypress open --e2e'",
    "test:e2e:ci": "npm run build && start-server-and-test preview http://localhost:4173/ 'cypress run --e2e'",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "ci": "npm run generate && npm run lint && npm run build && npm run test && npm run test:e2e:ci"
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.57.2",
    "@bufbuild/protobuf": "^2.9.0",
    "@bufbuild/protoc-gen-es": "^2.9.0",
    "@connectrpc/connect": "^2.1.0",
    "@connectrpc/connect-web": "^2.1.0",
    "@cypress/webpack-preprocessor": "^7.0.1",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.6.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cypress": "^15.3.0",
    "eslint": "^9.28.0",
    "eslint-plugin-chai-friendly": "^1.1.0",
    "eslint-plugin-cypress": "^5.1.1",
    "eslint-plugin-vue": "^10.5.0",
    "jiti": "^2.6.0",
    "jsdom": "^27.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "resolve-typescript-plugin": "^2.0.1",
    "start-server-and-test": "^2.1.2",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.0"
  }
}
